# ---------------------------------------------------------------------------
# Environment configuration template.
# Copy to `.env` and fill in real values. `.env` is gitignored — NEVER commit it.
# ---------------------------------------------------------------------------

# --- Core application ------------------------------------------------------
NODE_ENV=development
PORT=3001

# --- Database --------------------------------------------------------------
# PostgreSQL connection string (node-postgres / Neon).
DATABASE_URL=postgres://user:password@host:5432/dbname
# When "true", the server aborts startup if the on-boot migration step fails,
# instead of logging the error and continuing. Leave unset/false unless your
# schema is managed exclusively by these migrations.
DB_MIGRATE_STRICT=false

# --- Auth / sessions -------------------------------------------------------
# Required — server refuses to start if unset.
JWT_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-a-long-random-string
# Optional machine-to-machine token for internal service routes.
SYSTEM_INTERNAL_TOKEN=

# --- Deployment / ops scripts (scripts/*.ts, scripts/*.mjs) ----------------
# These scripts SSH into the production host. Credentials are read from the
# environment ONLY — they must never be hardcoded in source again.
#
# PREFERRED: key-based auth. Provide SSH_PRIVATE_KEY_PATH and leave
# SSH_PASSWORD empty. Password auth is a fallback for the interim only.
SSH_HOST=
SSH_USER=deploy
SSH_PORT=22
SSH_PASSWORD=
SSH_PRIVATE_KEY_PATH=
