# ADR-001 — Operational credentials for scripts under scripts/ that touch
# production (SSH, remote databases). COPY this file to `.env.ops` and fill in
# real values. `.env.ops` is gitignored and MUST NEVER be committed.
#
# Real production secrets are supplied here (or via the real environment /
# a secret manager in CI). No ops script contains a secret literal anymore —
# every one reads process.env.OPS_* through scripts/ops/credentials.mjs, and
# scripts/ops/run.mjs fails closed if any required value is missing.
#
# Run an ops script through the sanctioned wrapper:
#   node scripts/ops/run.mjs scripts/<script>.mjs

# --- Production SSH (rotate on the server; use key auth in production) ---
OPS_SSH_HOST=
OPS_SSH_USER=root
OPS_SSH_PASSWORD=

# --- Databases (include the real password inline in each URL) ---
OPS_DB_URL_POSTGRES=postgresql://postgres:<PASSWORD>@localhost:5432/postgres
OPS_DB_URL_NULIP_INVENTORY=postgresql://postgres:<PASSWORD>@localhost:5432/nulip_inventory
OPS_DB_URL_NULIP_INVENTORY_NULIP_USER=postgresql://nulip_user:<PASSWORD>@localhost:5432/nulip_inventory
OPS_DB_URL_NULIP_PERFORMANCE=postgresql://postgres:<PASSWORD>@localhost:5432/nulip_performance
OPS_DB_URL_STOKPRO_DB_NULIPUSER=postgresql://nulipuser:<PASSWORD>@localhost:5432/stokpro_db

# --- Misc ---
OPS_APP_TEST_PASSWORD=
