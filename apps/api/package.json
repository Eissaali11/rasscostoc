{
  "name": "@stockpro/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development PORT=3001 tsx src/server.ts",
    "build": "esbuild src/server.ts --platform=node --packages=external --bundle --format=esm --splitting --minify --sourcemap=external --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "express": "^4.21.2",
    "drizzle-orm": "^0.39.1",
    "dotenv": "^17.2.3",
    "bcryptjs": "^3.0.3",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "connect-pg-simple": "^10.0.0",
    "express-session": "^1.18.1",
    "memorystore": "^1.6.7",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "@stockpro/config": "*",
    "@stockpro/auth-sdk": "*",
    "@stockpro/shared-types": "*",
    "@stockpro/ai-extraction": "*"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.16.11",
    "typescript": "^5.6.3",
    "tsx": "^4.20.5",
    "esbuild": "^0.25.0",
    "cross-env": "^7.0.3",
    "vitest": "^2.1.9"
  }
}
